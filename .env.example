MONGO_URI=mongodb://localhost:27017/calcuttanode
JWT_SECRET=replace_with_any_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
PORT=5000

# These need real (free/sandbox) accounts even for local dev:
RAZORPAY_KEY_ID=your_test_key_here
RAZORPAY_KEY_SECRET=your_test_secret_here
EMAIL_USER=your_gmail_address_here
EMAIL_PASS=your_gmail_app_password_here

# Google OAuth (create credentials at https://console.cloud.google.com/)
GOOGLE_CLIENT_ID=your_google_client_id_here
